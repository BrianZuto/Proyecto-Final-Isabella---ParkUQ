<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="co.edu.uniquindio.parkuq.ui.controller.IngresoController"
      spacing="14" styleClass="form-panel" maxWidth="500">

    <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

    <Label text="Registro de Ingreso" styleClass="panel-title"/>

    <Label text="Tipo de Vehículo" styleClass="form-label"/>
    <ComboBox fx:id="cmbTipo" maxWidth="Infinity"/>

    <Label text="Placa" styleClass="form-label"/>
    <TextField fx:id="txtPlaca" promptText="Ej: ABC123" maxWidth="Infinity"/>

    <Label text="Nombre del Conductor" styleClass="form-label"/>
    <TextField fx:id="txtConductor" promptText="Nombre completo" maxWidth="Infinity"/>

    <Label text="Identificación del Conductor" styleClass="form-label"/>
    <TextField fx:id="txtIdentificacion" promptText="Número de documento" maxWidth="Infinity"/>

    <Button text="Registrar Ingreso" onAction="#onRegistrarIngreso"
            prefWidth="200" styleClass="btn-primary"/>

    <Label fx:id="lblMensaje" wrapText="true" styleClass="info-label"/>
    <Label fx:id="lblEspacio" styleClass="info-label"/>
</VBox>
