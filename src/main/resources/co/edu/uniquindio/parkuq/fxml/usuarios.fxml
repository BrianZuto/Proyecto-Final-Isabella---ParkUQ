<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="co.edu.uniquindio.parkuq.ui.controller.UsuariosController"
      spacing="12" styleClass="form-panel">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Gestión de Usuarios Autorizados" styleClass="panel-title"/>

    <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNombre"         text="Nombre"         prefWidth="180"/>
            <TableColumn fx:id="colIdentificacion" text="Identificación"  prefWidth="150"/>
            <TableColumn fx:id="colTipo"           text="Tipo"            prefWidth="130"/>
            <TableColumn fx:id="colDescuento"      text="Descuento"       prefWidth="90"/>
        </columns>
    </TableView>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Nombre:" styleClass="form-label"/>
        <TextField fx:id="txtNombre" promptText="Nombre completo" prefWidth="160"/>
        <Label text="ID:" styleClass="form-label"/>
        <TextField fx:id="txtIdentificacion" promptText="Identificación" prefWidth="130"/>
        <Label text="Tipo:" styleClass="form-label"/>
        <ComboBox fx:id="cmbTipo" prefWidth="140"/>
        <Button text="Agregar" onAction="#onAgregar" styleClass="btn-primary"/>
    </HBox>

    <HBox spacing="12">
        <Button text="Eliminar seleccionado" onAction="#onEliminar" styleClass="btn-danger"/>
    </HBox>

    <Label fx:id="lblMensaje" wrapText="true"/>
</VBox>
