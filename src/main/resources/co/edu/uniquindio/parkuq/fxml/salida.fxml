<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="co.edu.uniquindio.parkuq.ui.controller.SalidaController"
      spacing="16" styleClass="form-panel" maxWidth="450">

    <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

    <Label text="Registro de Salida" styleClass="panel-title"/>

    <Label text="Placa del Vehículo" styleClass="form-label"/>
    <TextField fx:id="txtPlaca" promptText="Ej: ABC123"/>

    <Button text="Registrar Salida" onAction="#onRegistrarSalida"
            prefWidth="200" styleClass="btn-primary"/>

    <Label fx:id="lblMensaje" wrapText="true" styleClass="info-label"/>
    <Label fx:id="lblCobro"   styleClass="cobro-label"/>
</VBox>
