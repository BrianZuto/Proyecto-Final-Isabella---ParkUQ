<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="co.edu.uniquindio.parkuq.ui.controller.TarifasController"
      spacing="14" styleClass="form-panel">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Gestión de Tarifas" styleClass="panel-title"/>

    <TableView fx:id="tablaTarifas" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTipo"      text="Tipo Vehículo"   prefWidth="160"/>
            <TableColumn fx:id="colValor"     text="Valor/Hora ($)"  prefWidth="160"/>
            <TableColumn fx:id="colDescuento" text="Descuento (%)"   prefWidth="130"/>
        </columns>
    </TableView>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Tipo:" styleClass="form-label"/>
        <ComboBox fx:id="cmbTipo" prefWidth="140"/>
        <Label text="Valor/Hora:" styleClass="form-label"/>
        <TextField fx:id="txtValor" promptText="Ej: 3000" prefWidth="100"/>
        <Label text="Descuento %:" styleClass="form-label"/>
        <TextField fx:id="txtDescuento" promptText="0" prefWidth="60"/>
        <Button text="Actualizar" onAction="#onActualizar" styleClass="btn-primary"/>
    </HBox>

    <Label fx:id="lblMensaje" wrapText="true"/>
</VBox>
