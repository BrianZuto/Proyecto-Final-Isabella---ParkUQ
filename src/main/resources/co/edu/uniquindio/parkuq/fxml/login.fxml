<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="co.edu.uniquindio.parkuq.ui.controller.LoginController"
      alignment="CENTER"
      spacing="20"
      prefWidth="800"
      prefHeight="600">

    <padding>
        <Insets top="80" right="200" bottom="80" left="200"/>
    </padding>

    <!-- Título -->
    <Label text="PARKUQ – Iniciar Sesión"
           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <!-- Campo usuario -->
    <TextField fx:id="txtUsuario"
               promptText="Usuario"
               maxWidth="300"/>

    <!-- Campo contraseña -->
    <PasswordField fx:id="txtContrasena"
                   promptText="Contraseña"
                   maxWidth="300"/>

    <!-- Botón Ingresar -->
    <Button fx:id="btnIngresar"
            text="Ingresar"
            onAction="#onIngresarClick"
            prefWidth="150"/>

</VBox>
